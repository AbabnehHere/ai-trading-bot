# ============================================
# Polymarket Trading Bot — Environment Variables
# ============================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- REQUIRED FOR LIVE TRADING (not needed for paper trading) ---
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_SECRET=your_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here
PRIVATE_KEY=your_wallet_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# --- REQUIRED FOR INTELLIGENT ANALYSIS ---
# Claude API — powers news analysis, probability estimation, trade review,
# and the midnight strategy improvement cycle
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OPTIONAL BUT RECOMMENDED ---
# Bookmaker odds for sports markets (free tier: 500 req/month)
# Sign up at: https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key_here

# --- OPTIONAL ---
# Telegram notifications for trade alerts and daily summaries
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Environment
ENV=development  # development | production
LOG_LEVEL=INFO
